#!/bin/sh
set -e
set -x

ENV_FILE="${ENV_FILE:-.env}"

configure() {
    if [ ! -f "$ENV_FILE" ]; then
        yellow "$ENV_FILE file not found. Creating template..."
        cat > "$ENV_FILE" << 'EOF'
# Set the correct environment information below:
API_URL="https://api.bitwarden.com"
IDENTITY_URL="https://identity.bitwarden.com"
ORGANIZATION_ID="<your-organization-id-here>"
ACCESS_TOKEN="<your-access-token-here>"
EOF
        printf "\n"
    fi

    # Check if required values are set
    if grep -q 'API_URL=' "$ENV_FILE" && \
       grep -q 'IDENTITY_URL=' "$ENV_FILE" && \
       grep -q 'ORGANIZATION_ID=' "$ENV_FILE" && \
       grep -q 'ACCESS_TOKEN=' "$ENV_FILE"; then
        # Check if placeholder values are still there
        if grep -q 'your-organization-id-here' "$ENV_FILE"; then
            return 1  # Needs editing
        fi
        if grep -q 'your-access-token-here' "$ENV_FILE"; then
            return 1  # Needs editing
        fi
        return 0  # Already configured
    fi
    return 1  # Needs editing
}

interactive() {
    cyan_bold "\n=== Go SDK Testing ==="
    printf "\n"
    if ! configure; then
        yellow "Opening $ENV_FILE file for editing..."
        editor="${EDITOR:-${VISUAL:-vi}}"
        "$editor" "$ENV_FILE"

        printf "\n"
        if ! configure; then
            red "Error: Required $ENV_FILE values are not properly configured. Aborting."
            exit 1
        fi
        green "$ENV_FILE configured successfully."
    else
        green "$ENV_FILE is already configured."
    fi

    # Ask user which mode to run
    printf "\n"
    cyan_bold "Select mode:"
    printf "  1) prod - Use latest released Go SDK\n"
    printf "  2) test - Use test build from a branch\n"
    printf "  3) help - Show help\n"
    printf "  4) exit - Exit\n"
    printf "\nEnter your choice (1-4): "
    read -r choice

    case "$choice" in
        1)
            green "Running the Go project with the latest released provider version..."
            prod
            ;;
        2)
            printf "Enter the branch name to test: "
            read -r branch_name
            if [ -z "$branch_name" ]; then
                red "Error: Branch name cannot be empty."
                exit 1
            fi
            green "Running the Go project with a test provider build from a specified branch..."
            test "$branch_name"
            ;;
        3)
            docs
            ;;
        4)
            cyan "Exiting."
            exit 0
            ;;
        *)
            red "Invalid choice. Please enter 1, 2, 3, or 4."
            exit 1
            ;;
    esac
}

main() {
    # If no arguments provided, run interactive mode
    if [ $# -eq 0 ]; then
        interactive
        exit 0
    fi

    if [ "$1" = "help" ] || [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
        docs
        exit 0
    fi

    # Handle other commands here
    case "$1" in
        prod)
            green "Running the Go project with the latest released Go SDK..."
            prod
            ;;
        test)
            green "Running the Go project with a test build from a feature branch..."
            test "$2"
            ;;
        *)
            red "Unknown command: $1"
            printf "\n"
            docs
            exit 1
            ;;
    esac
}

prod() {
    clone_sdk

    if grep -qe '^replace' go.mod; then
        # comment-out the replacement directive in go.mod
        sed 's/replace/\/\/ replace/' go.mod > go.mod.tmp
        mv go.mod.tmp go.mod
    fi

    if grep -qe '^require' go.mod; then
        # delete explicit require directive
        sed '/^require/d' go.mod > go.mod.tmp
        mv go.mod.tmp go.mod
    fi

    rm -f go.sum
    go mod tidy
    go run .

    green_bold "Project built successfully with the latest released Go SDK!"
}

test() {
    branch_to_test="$1"

    if [ -z "$branch_to_test" ]; then
        red "Error: No branch specified for testing. Please provide the branch name as an argument."
        printf "Usage: $0 test <branch-name>\n"
        exit 1
    fi

    clone_sdk

    # download libbitwarden_c
    latest_run_id="$(gh run list -R bitwarden/sdk-sm --branch "$branch_to_test" --workflow "Build Rust Cross Platform" --json databaseId --jq '.[0].databaseId')"
    if [ -z "$latest_run_id" ]; then
        red "Error: No successful workflow runs found for branch '$branch_to_test'. Please ensure there is a successful run for that branch before testing."
        exit 1
    fi

    artifact_string=libbitwarden_c_files-${ARCH}-${OS}

    artifact_name="$(gh api "repos/bitwarden/sdk-sm/actions/runs/$latest_run_id/artifacts" --jq ".artifacts[].name | select(test(\"${artifact_string}$\"))" | head -n 1)"
    if [ -z "$artifact_name" ]; then
      red "Error: No matching artifact found for '${artifact_string}' in run '${latest_run_id}'."
      exit 1
    fi

    # ensure the temp dir is clean
    rm -rf /tmp/test-artifact

    # Download the artifact for the latest run
    gh run download "$latest_run_id" -R bitwarden/sdk-sm --name "$artifact_name" --dir /tmp/test-artifact || fish

    _os="$(uname -s | tr '[:upper:]' '[:lower:]')"
    _go_arch="$(uname -m | sed 's/x86_64/x64/' | sed 's/aarch64/arm64/')"
    
    mkdir -p ./sdk-sm/languages/go/internal/cinterface/lib/"${_os}-${_go_arch}"
    mv /tmp/test-artifact/libbitwarden_c.a ./sdk-sm/languages/go/internal/cinterface/lib/"${_os}-${_go_arch}"

    # download schemas.go
    # TODO: we need to make the 'Generate schemas' workflow run on all branches so we don't have to pull from main
    latest_run_id="$(gh run list -R bitwarden/sdk-sm --branch main --workflow "Generate schemas" --json databaseId --jq '.[0].databaseId')"
    if [ -z "$latest_run_id" ]; then
        red "Error: No successful workflow runs found for branch '$branch_to_test'. Please ensure there is a successful run for that branch before testing."
        exit 1
    fi

    artifact_name="$(gh api "repos/bitwarden/sdk-sm/actions/runs/$latest_run_id/artifacts" --jq ".artifacts[].name | select(test(\"schemas.go$\"))" | head -n 1)"
    if [ -z "$artifact_name" ]; then
      red "Error: No matching artifact found for 'schemas.go' in run '${latest_run_id}'."
      exit 1
    fi

    # Download the artifact for the latest run
    gh run download "$latest_run_id" -R bitwarden/sdk-sm --name "$artifact_name" --dir /tmp/test-artifact || fish

    mv /tmp/test-artifact/schema.go ./sdk-sm/languages/go/
    
    rm -rf /tmp/test-artifact

    if grep -qe '^// replace' go.mod; then
        # uncomment the replacement directive in go.mod
        sed 's/\/\/ replace/replace/' go.mod > go.mod.tmp
        mv go.mod.tmp go.mod
    fi

    if grep -qe '^require' go.mod; then
        # delete explicit require directive
        sed '/^require/d' go.mod > go.mod.tmp
        mv go.mod.tmp go.mod
    fi

    rm -f go.sum
    go mod tidy
    go run .
    
    green_bold "Project built successfully with the Go SDK build from branch '$branch_to_test'!"
}

clone_sdk() {
    if [ ! -d "sdk-sm" ]; then
        yellow "Cloning bitwarden/sdk-sm..."
        git clone https://github.com/bitwarden/sdk-sm.git
    else
        green "sdk-sm already exists, skipping clone."
    fi

    if [ -d "sdk-sm/languages/go" ]; then
        green "Found Go SDK at sdk-sm/languages/go"
    else
        red "Error: Go SDK not found at sdk-sm/languages/go"
        exit 1
    fi
}

OS="$(if [ "$(uname)" = "Darwin" ]; then echo "apple-darwin"; else echo "unknown-linux-musl"; fi)"
ARCH="$(uname -m)"

cyan() {
  printf "\033[36m$1\033[0m\n"
}

cyan_bold() {
  printf "\033[1;36m$1\033[0m\n"
}

green() {
  printf "\033[32m$1\033[0m\n"
}

green_bold() {
  printf "\033[1;32m$1\033[0m\n"
}

yellow() {
  printf "\033[33m$1\033[0m\n"
}

yellow_bold() {
  printf "\033[1;33m$1\033[0m\n"
}

red() {
  printf "\033[31m$1\033[0m\n"
}

red_bold() {
  printf "\033[1;31m$1\033[0m\n"
}

docs() {
  cat << EOF
Usage: $0 [OPTIONS] COMMAND

Options:
  $(cyan_bold "-h, --help")    Show this help message and exit

Commands:
  $(cyan_bold "prod")    Build the project for production
  $(cyan_bold "test")    Run tests
EOF
}

main "$@"
